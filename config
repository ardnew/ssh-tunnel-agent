# config

#   This file is sourced by ssh-tunnel-agent to set the default configuration.
#   It is searched for in the following order:
#
#   - "${XDG_CONFIG_HOME:-${HOME}/.config}/ssh-tunnel-agent/config"
#   - "${HOME}/.local/etc/ssh-tunnel-agent/config"
#   - "/usr/local/etc/ssh-tunnel-agent/config"
#   - "/usr/etc/ssh-tunnel-agent/config"
#   - "/etc/ssh-tunnel-agent/config"

# SSH Connection Settings
ssh_host="proxyhost"
ssh_port="22"
ssh_user="${USER}"
ssh_term="xterm-256color"

# Tunnel Definitions
# Two parallel arrays: tunnel_names[i] corresponds to tunnel_specs[i]
# Spec format: "type:spec type:spec ..."
#
# Tunnel Types:
#   L:localport:remotehost:remoteport  - Local port forward
#   D:localport                        - Dynamic SOCKS proxy
#   R:remoteport:localhost:localport   - Remote port forward
#
# Examples:
#   tunnel_names+=( "web" )
#   tunnel_specs+=( "L:8080:webserver:80" )
#
#   tunnel_names+=( "multi" )
#   tunnel_specs+=( "L:3000:srv1:3000 L:4000:srv2:4000" )

declare -a tunnel_names
declare -a tunnel_specs

tunnel_names+=( "svn" )
tunnel_specs+=( "L:3690:remotehost:3690 L:3343:remotehost:3343" )

tunnel_names+=( "jira" )
tunnel_specs+=( "L:8081:remotehost:8081" )

tunnel_names+=( "socks" )
tunnel_specs+=( "D:65135" )

# Optional: Enable debug logging
# DEBUG=1
